{
  "name": "kai",
  "version": "0.5.1",
  "description": "Kai - A programming language for ML/AI development with bytecode VM (263× faster)",
  "main": "kai.js",
  "bin": {
    "kai": "./kai.js"
  },
  "scripts": {
    "test": "node kai.js tests/basic.kai",
    "repl": "node kai.js",
    "blog:build": "cd blog && bundle exec jekyll build --destination ../_site/blog",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:test": "vitepress build docs && npm run docs:link-check",
    "docs:link-check": "markdown-link-check -c docs/.vitepress/link-check-config.json",
    "site:merge": "node blog/scripts/build-pages.mjs"
  },
  "keywords": [
    "programming-language",
    "ml",
    "ai",
    "jit",
    "compiler"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "vitepress": "^1.0.0",
    "vue": "^3.4.0",
    "markdown-link-check": "^3.12.0",
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  }
}
